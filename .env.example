# LLM — Ollama Cloud
OLLAMA_API_KEY=your_ollama_api_key_here

# LangSmith observability (free tier, highly recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=clouddash-support

# App
APP_ENV=development
LOG_LEVEL=INFO

# ChromaDB
CHROMA_PERSIST_DIR=./data/chromadb
CHROMA_COLLECTION_NAME=clouddash_kb

# API
API_HOST=0.0.0.0
API_PORT=8000
